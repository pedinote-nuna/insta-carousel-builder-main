# Gemini 3.0 Pro Image (나노바나나 Pro) API 키 — 이미지 생성용
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic API — 텔레그램 봇 /topics 주제 추천 + (옵션) 품질 체크
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 텔레그램 봇 — 운영자가 모바일에서 카드뉴스 생성 트리거 + 결과 수신
# 봇 발급: https://t.me/BotFather → /newbot → 토큰 발급
# chat_id 확인: 봇에 메시지 1개 보낸 뒤 https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
